# Python bytecode and test caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Python package/build metadata
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/
ENV/

.agents/
.codex/

# Local configuration and secrets
.env
.env.*
!.env.example
*.env
*.key
*.pem
*.p12
*.pfx
secrets/
credentials/
config.local.*

# Private project data: screenshots and annotations can contain personal data
data/
!data/.gitkeep

# Generated OCR outputs and debug artifacts
outputs/
!outputs/.gitkeep

# Logs and temporary files
*.log
logs/
tmp/
temp/
*.tmp
*.bak

# OS and editor noise
.DS_Store
Thumbs.db
desktop.ini
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json

